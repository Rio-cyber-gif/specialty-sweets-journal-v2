<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# ヘッダー部分 %>
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold" style="color: #471e0a;">銘菓一覧</h1>
    <% if user_signed_in? %>
      <%= link_to '新規登録', new_specialty_path, 
          class: 'bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2.5 rounded-lg transition duration-200 shadow-sm hover:shadow-md' %>
    <% end %>
  </div>

  <%# 検索フォーム %>
  <div class="bg-white rounded-xl shadow-sm border p-4 mb-8" style="border-color: #e8d5c4;">
    <%= search_form_for @q, url: specialties_path, html: { class: "flex flex-wrap gap-3 items-end" } do |f| %>
      <div class="flex-1 min-w-40">
        <%= f.search_field :name_cont,
            placeholder: "銘菓名で検索...",
            class: "w-full px-3 py-2 text-sm rounded-md border focus:outline-none focus:ring-1",
            style: "border-color: #d4a574; color: #471e0a;" %>
      </div>
      <div class="min-w-36">
        <%= f.collection_select :region_id_eq, @regions, :id, :name,
            { include_blank: "地域を選択" },
            class: "w-full px-3 py-2 text-sm rounded-md border focus:outline-none focus:ring-1",
            style: "border-color: #d4a574; color: #471e0a;" %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "検索",
            class: "px-4 py-2 text-sm font-medium text-white rounded-md cursor-pointer",
            style: "background-color: #d4a574;" %>
        <%= link_to "クリア", specialties_path,
            class: "px-4 py-2 text-sm font-medium rounded-md border",
            style: "color: #471e0a; border-color: #d4a574;" %>
      </div>
    <% end %>
  </div>

  <%# 地方ブロックフィルターバナー %>
  <% if @region_block_name.present? %>
    <div class="flex items-center gap-3 mb-4 px-4 py-2.5 rounded-lg text-sm" style="background-color: #f5ece0; color: #8b7355; border: 1px solid #d4a574;">
      <span>🗾 <strong><%= @region_block_name %></strong> の銘菓</span>
      <%= link_to specialties_path, class: 'ml-auto text-xs font-medium', style: 'color: #a89080;' do %>
        ✕ クリア
      <% end %>
    </div>
  <% end %>

  <%# タグフィルター中のバナー %>
  <% if params[:tag].present? %>
    <div class="flex items-center gap-3 mb-4 px-4 py-2.5 rounded-lg text-sm" style="background-color: #f5ece0; color: #8b7355; border: 1px solid #d4a574;">
      <span><strong>#<%= params[:tag] %></strong> のタグが付いた銘菓</span>
      <%= link_to specialties_path, class: 'ml-auto text-xs font-medium', style: 'color: #a89080;' do %>
        ✕ クリア
      <% end %>
    </div>
  <% end %>

  <%# ソートタブ %>
  <div class="flex items-center gap-2 mb-4">
    <% sort_tabs = [['新着順', nil], ['人気順', 'popular'], ['コメント多い順', 'comments']] %>
    <% sort_tabs.each do |label, value| %>
      <% active = params[:sort] == value %>
      <%= link_to label, specialties_path(q: params[:q], tag: params[:tag], sort: value),
          class: "px-3 py-1.5 text-xs font-medium rounded-full border transition",
          style: active ? "background-color: #471e0a; color: #f5f5f0; border-color: #471e0a;" : "color: #8b7355; border-color: #d4a574; background: white;" %>
    <% end %>
  </div>

  <%# 銘菓が存在する場合 %>
  <% if @specialties.present? %>
    <%# グリッドレイアウト: スマホ1列、タブレット2列、PC3列 %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @specialties.each do |specialty| %>
        <%= link_to specialty_path(specialty), class: 'block group' do %>
          <div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 h-full border overflow-hidden" 
               style="border-color: #e8d5c4;">
            
            <%# 画像部分 %>
            <% if specialty.image.attached? %>
              <%= image_tag specialty.image.variant(resize_to_fill: [400, 300]),
                  class: 'w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300',
                  loading: 'lazy' %>
            <% else %>
              <div class="w-full h-48 flex items-center justify-center" style="background-color: #f5f0eb;">
                <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
            <% end %>

            <%# カード本体 %>
            <div class="p-4">
              <%# タイトル %>
              <h5 class="text-xl font-bold mb-3" style="color: #471e0a;">
                <%= specialty.name %>
              </h5>

              <%# 地域表示 %>
              <div class="flex items-center mb-3 text-sm" style="color: #471e0a;">
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span><%= specialty.region.name %></span>
              </div>

              <%# 説明文（2行で切り詰め） %>
              <% if specialty.description.present? %>
                <p class="text-sm leading-relaxed overflow-hidden"
                   style="color: #471e0a; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                  <%= specialty.description %>
                </p>
              <% end %>

              <%# タグ %>
              <% if specialty.tags.any? %>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% specialty.tags.each do |tag| %>
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs"
                          style="background-color: #f5ece0; color: #8b7355; border: 1px solid #e8d5c4;">
                      #<%= tag.name %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%# カードフッター %>
            <div class="px-4 pb-4 flex items-center justify-between">
              <p class="text-xs" style="color: #a89080;">
                投稿者: <%= specialty.user&.decorate&.full_name || '未設定' %>
              </p>
              <span class="text-xs" style="color: #a89080;">♡ <%= specialty.favorites.size %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <%# ページネーション部分を追加 %>
    <div class="mt-8 flex justify-center">
      <%= paginate @specialties, params: { sort: params[:sort], tag: params[:tag] } %>
    </div>
  <%# 銘菓が存在しない場合 %>
  <% else %>
    <div class="text-center py-16">
      <div class="text-gray-400 mb-6">
        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
      </div>
      <p class="text-gray-500 text-lg mb-6">
        まだ銘菓が登録されていません
      </p>
      <% if user_signed_in? %>
        <%= link_to '最初の銘菓を登録する', new_specialty_path, 
            class: 'inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg transition duration-200 shadow-sm hover:shadow-md' %>
      <% end %>
    </div>
  <% end %>
</div>