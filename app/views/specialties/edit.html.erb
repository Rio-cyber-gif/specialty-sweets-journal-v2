<div class="min-h-screen" style="background-color: #f5f5f0;">
  <div class="container mx-auto px-4 py-12">
    
    <%# 戻るボタン(中央配置) %>
    <div class="mb-6 max-w-4xl mx-auto">
      <%= link_to specialty_path(@specialty), class: "inline-flex items-center px-4 py-2 text-sm font-medium border rounded-md transition-colors hover:shadow-md", style: "color: #471e0a; background-color: white; border-color: #d4a574;" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        詳細に戻る
      <% end %>
    </div>

    <%# メインコンテンツ(カード幅を変更) %>
    <div class="max-w-4xl mx-auto bg-white rounded-lg shadow-lg p-8" style="border: 2px solid #d4a574;">
      <h1 class="text-3xl md:text-4xl font-bold mb-8 tracking-wider font-serif text-center" style="color: #471e0a;">
        銘菓情報の編集
      </h1>

      <%= form_with model: @specialty, local: true, class: "space-y-6" do |f| %>
        <%# エラーメッセージ表示 %>
        <% if @specialty.errors.any? %>
          <div class="border rounded-lg px-4 py-3" style="background-color: #fef2f2; border-color: #dc2626; color: #991b1b;">
            <h3 class="font-bold mb-2"><%= @specialty.errors.count %>件のエラーがあります:</h3>
            <ul class="list-disc list-inside">
              <% @specialty.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# 銘菓名 %>
        <div>
          <%= f.label :name, "銘菓名", class: "block text-sm font-medium mb-2", style: "color: #471e0a;" %>
          <%= f.text_field :name, class: "w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-amber-400 transition-all", style: "border-color: #d4a574;", placeholder: "例: 八ッ橋" %>
        </div>

        <%# 地域 %>
        <div>
          <%= f.label :region_id, "地域", class: "block text-sm font-medium mb-2", style: "color: #471e0a;" %>
          <%= f.select :region_id,
                       grouped_options_for_select(@grouped_regions, @specialty.region_id),
                       { prompt: '地域を選択してください' },
                       { class: 'w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-amber-400 transition-all',
                         style: 'border-color: #d4a574;' } %>
        </div>

        <%# 説明 %>
        <div>
          <%= f.label :description, "説明", class: "block text-sm font-medium mb-2", style: "color: #471e0a;" %>
          <%= f.text_area :description, rows: 6, class: "w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-amber-400 transition-all", style: "border-color: #d4a574;", placeholder: "銘菓の特徴や魅力を入力してください" %>
        </div>

        <%# タグ %>
        <div>
          <%= f.label :tag_list, 'タグ（オプション）', class: 'block text-sm font-medium mb-2', style: 'color: #471e0a;' %>
          <%= f.text_field :tag_list,
                           class: 'w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-amber-400 transition-all',
                           style: 'border-color: #d4a574;',
                           placeholder: '例: 和菓子, 焼き菓子, 贈り物' %>
          <p class="text-xs mt-1" style="color: #a89080;">カンマ区切りで複数入力できます</p>
        </div>

        <%# 画像 %>
        <div>
          <%= f.label :image, "画像", class: "block text-sm font-medium mb-2", style: "color: #471e0a;" %>

          <%# 現在の画像 / プレビュー表示エリア %>
          <div class="mb-4">
            <% if @specialty.image.attached? && @specialty.image.blob&.persisted? %>
              <p class="text-sm mb-2" id="image_label_text" style="color: #6b5744;">現在の画像:</p>
              <img id="image_preview"
                   src="<%= @specialty.image.url %>"
                   alt="プレビュー"
                   class="object-cover rounded-md border-2"
                   style="width: 256px; height: 192px; border-color: #d4a574;" />
              <div class="mt-3 flex items-center gap-2">
                <input type="hidden" name="specialty[remove_image]" value="0">
                <input type="checkbox" name="specialty[remove_image]" id="specialty_remove_image" value="1"
                       class="w-4 h-4 cursor-pointer" style="accent-color: #dc2626;">
                <label for="specialty_remove_image" class="text-sm cursor-pointer" style="color: #dc2626;">
                  現在の画像を削除する
                </label>
              </div>
            <% else %>
              <p class="text-sm mb-2" id="image_label_text" style="display: none; color: #6b5744;">選択した画像のプレビュー:</p>
              <img id="image_preview" src="" alt="プレビュー"
                   class="object-cover rounded-md border-2"
                   style="display: none; width: 256px; height: 192px; border-color: #d4a574;" />
            <% end %>
          </div>

          <%= f.file_field :image, id: 'specialty_image_input', accept: "image/*", class: "w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-2 focus:ring-amber-400 transition-all", style: "border-color: #d4a574;" %>
          <p class="text-xs mt-1" style="color: #a89080;">対応形式: JPG / JPEG / PNG（5MB以下）</p>
          <p class="text-sm mt-1" style="color: #6b5744;">ファイルを選択すると現在の画像が更新されます</p>
        </div>
        <script>
          document.getElementById('specialty_image_input').addEventListener('change', function(e) {
            var file = e.target.files[0];
            var preview = document.getElementById('image_preview');
            var label = document.getElementById('image_label_text');
            if (file && file.type.startsWith('image/')) {
              preview.src = URL.createObjectURL(file);
              preview.style.display = 'block';
              label.textContent = '選択した画像のプレビュー:';
              label.style.display = 'block';
            }
          });
        </script>

        <%# 送信ボタン %>
        <div class="flex gap-4 pt-4">
          <%= f.submit "下書き保存", name: "draft",
              class: "flex-1 px-6 py-3 rounded-md transition-all font-medium cursor-pointer hover:shadow-lg",
              style: "color: #8b7355; background-color: white; border: 2px solid #8b7355;",
              data: { turbo_submits_with: "保存中..." } %>
          <%= f.submit "更新・公開する",
              class: "flex-1 px-6 py-3 rounded-md transition-all font-medium cursor-pointer text-white hover:shadow-lg",
              style: "background-color: #471e0a;",
              data: { turbo_submits_with: "更新中..." } %>
          <%= link_to "キャンセル", specialty_path(@specialty),
              class: "flex-1 px-6 py-3 rounded-md transition-all font-medium text-center border-2 hover:shadow-lg",
              style: "color: #471e0a; background-color: white; border-color: #d4a574;" %>
        </div>
      <% end %>
    </div>
  </div>
</div>