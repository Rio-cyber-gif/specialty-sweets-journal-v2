<% content_for :page_title, 'ダッシュボード' %>

<%# 統計カード %>
<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-bottom: 2rem;">
  <div style="background: white; border-radius: 10px; padding: 1.5rem; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06);">
    <p style="margin: 0 0 0.5rem; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: #a89080;">ユーザー数</p>
    <p style="margin: 0; font-size: 2.25rem; font-weight: 700; color: #471e0a; font-family: serif;"><%= @users_count %></p>
    <p style="margin: 0.5rem 0 0; font-size: 0.75rem; color: #a89080;">登録済みユーザー</p>
  </div>

  <div style="background: white; border-radius: 10px; padding: 1.5rem; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06);">
    <p style="margin: 0 0 0.5rem; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: #a89080;">銘菓数</p>
    <p style="margin: 0; font-size: 2.25rem; font-weight: 700; color: #471e0a; font-family: serif;"><%= @specialties_count %></p>
    <p style="margin: 0.5rem 0 0; font-size: 0.75rem; color: #a89080;">登録済み銘菓</p>
  </div>
</div>

<%# 管理メニュー %>
<div style="background: white; border-radius: 10px; padding: 1.5rem; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06);">
  <p style="margin: 0 0 1.25rem; font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; color: #a89080;">クイックアクセス</p>
  <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
    <%= link_to admin_users_path,
        style: "display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; background-color: #471e0a; color: #f5f5f0; border-radius: 6px; text-decoration: none; font-size: 0.875rem;" do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      ユーザー一覧
    <% end %>
    <%= link_to admin_specialties_path,
        style: "display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1.25rem; background-color: #d4a574; color: white; border-radius: 6px; text-decoration: none; font-size: 0.875rem;" do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      銘菓一覧
    <% end %>
  </div>
</div>
