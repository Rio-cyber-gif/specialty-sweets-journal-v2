<% content_for :page_title, 'お菓子管理' %>

<div style="background: white; border-radius: 10px; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06); overflow: hidden;">
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="background-color: #faf6f2; border-bottom: 2px solid #e8d5c4;">
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">ID</th>
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">お菓子名</th>
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">銘菓</th>
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">投稿者</th>
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">登録日</th>
        <th style="padding: 0.875rem 1.25rem; text-align: left; font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: #a89080; font-weight: 600;">操作</th>
      </tr>
    </thead>
    <tbody>
      <% @sweets.each_with_index do |sweet, i| %>
        <tr style="border-bottom: 1px solid #f0e6dc; <%= i.even? ? '' : 'background-color: #fdfcfb;' %>">
          <td style="padding: 0.875rem 1.25rem; font-size: 0.8rem; color: #a89080;">#<%= sweet.id %></td>
          <td style="padding: 0.875rem 1.25rem; font-size: 0.875rem; color: #471e0a; font-weight: 500;"><%= sweet.name %></td>
          <td style="padding: 0.875rem 1.25rem; font-size: 0.875rem; color: #8b7355;"><%= sweet.specialty&.name || '未設定' %></td>
          <td style="padding: 0.875rem 1.25rem; font-size: 0.8rem; color: #a89080;"><%= sweet.user&.email || '削除済み' %></td>
          <td style="padding: 0.875rem 1.25rem; font-size: 0.8rem; color: #a89080;"><%= sweet.created_at.strftime('%Y/%m/%d %H:%M') %></td>
          <td style="padding: 0.875rem 1.25rem;">
            <%= link_to '編集', edit_admin_sweet_path(sweet), style: 'font-size: 0.8rem; color: #d4a574; text-decoration: none; margin-right: 1rem; font-weight: 500;' %>
            <%= link_to '削除', admin_sweet_path(sweet), data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' }, style: 'font-size: 0.8rem; color: #c0392b; text-decoration: none; font-weight: 500;' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
