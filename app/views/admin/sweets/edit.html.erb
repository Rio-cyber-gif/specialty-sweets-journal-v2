<% content_for :page_title, 'お菓子編集' %>

<div style="max-width: 560px;">
  <div style="background: white; border-radius: 10px; padding: 2rem; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06);">
    <%= form_with model: @sweet, url: admin_sweet_path(@sweet), method: :patch, local: true do |f| %>
      <% if @sweet.errors.any? %>
        <div style="background-color: #fdf0f0; color: #721c24; padding: 0.875rem 1rem; margin-bottom: 1.5rem; border-radius: 6px; font-size: 0.875rem; border-left: 3px solid #c0392b;">
          <p style="margin: 0 0 0.5rem; font-weight: 600;"><%= @sweet.errors.count %>件のエラーがあります</p>
          <ul style="margin: 0; padding-left: 1.25rem;">
            <% @sweet.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :name, 'お菓子名', style: 'display: block; margin-bottom: 0.4rem; font-size: 0.8rem; font-weight: 600; color: #471e0a; letter-spacing: 0.03em;' %>
        <%= f.text_field :name, style: 'width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e8d5c4; border-radius: 6px; font-size: 0.875rem; color: #471e0a; box-sizing: border-box;' %>
      </div>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :description, '説明', style: 'display: block; margin-bottom: 0.4rem; font-size: 0.8rem; font-weight: 600; color: #471e0a; letter-spacing: 0.03em;' %>
        <%= f.text_area :description, rows: 5, style: 'width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e8d5c4; border-radius: 6px; font-size: 0.875rem; color: #471e0a; box-sizing: border-box; resize: vertical;' %>
      </div>

      <div style="margin-bottom: 1.75rem;">
        <%= f.label :specialty_id, '銘菓', style: 'display: block; margin-bottom: 0.4rem; font-size: 0.8rem; font-weight: 600; color: #471e0a; letter-spacing: 0.03em;' %>
        <%= f.collection_select :specialty_id, Specialty.all, :id, :name, { prompt: '選択してください' }, style: 'width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e8d5c4; border-radius: 6px; font-size: 0.875rem; color: #471e0a; background-color: white; box-sizing: border-box;' %>
      </div>

      <div style="display: flex; align-items: center; gap: 1rem;">
        <%= f.submit '更新する', style: 'padding: 0.625rem 1.5rem; background-color: #471e0a; color: #f5f5f0; border: none; border-radius: 6px; cursor: pointer; font-size: 0.875rem; font-weight: 500;' %>
        <%= link_to 'キャンセル', admin_sweets_path, style: 'font-size: 0.875rem; color: #a89080; text-decoration: none;' %>
      </div>
    <% end %>
  </div>
</div>
