<% content_for :page_title, 'ユーザー編集' %>

<div style="max-width: 560px;">
  <div style="background: white; border-radius: 10px; padding: 2rem; border: 1px solid #e8d5c4; box-shadow: 0 1px 4px rgba(71,30,10,0.06);">
    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, local: true do |f| %>
      <% if @user.errors.any? %>
        <div style="background-color: #fdf0f0; color: #721c24; padding: 0.875rem 1rem; margin-bottom: 1.5rem; border-radius: 6px; font-size: 0.875rem; border-left: 3px solid #c0392b;">
          <p style="margin: 0 0 0.5rem; font-weight: 600;"><%= @user.errors.count %>件のエラーがあります</p>
          <ul style="margin: 0; padding-left: 1.25rem;">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :email, 'メールアドレス', style: 'display: block; margin-bottom: 0.4rem; font-size: 0.8rem; font-weight: 600; color: #471e0a; letter-spacing: 0.03em;' %>
        <%= f.email_field :email, style: 'width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e8d5c4; border-radius: 6px; font-size: 0.875rem; color: #471e0a; box-sizing: border-box; outline: none;' %>
      </div>

      <div style="margin-bottom: 1.75rem;">
        <%= f.label :role, '権限', style: 'display: block; margin-bottom: 0.4rem; font-size: 0.8rem; font-weight: 600; color: #471e0a; letter-spacing: 0.03em;' %>
        <%= f.select :role, User.roles.keys.map { |role| [I18n.t("enums.user.role.#{role}"), role] }, {}, style: 'width: 100%; padding: 0.625rem 0.75rem; border: 1px solid #e8d5c4; border-radius: 6px; font-size: 0.875rem; color: #471e0a; background-color: white; box-sizing: border-box;' %>
      </div>

      <div style="display: flex; align-items: center; gap: 1rem;">
        <%= f.submit '更新する', style: 'padding: 0.625rem 1.5rem; background-color: #471e0a; color: #f5f5f0; border: none; border-radius: 6px; cursor: pointer; font-size: 0.875rem; font-weight: 500;' %>
        <%= link_to 'キャンセル', admin_users_path, style: 'font-size: 0.875rem; color: #a89080; text-decoration: none;' %>
      </div>
    <% end %>
  </div>
</div>
