<div class="container mx-auto px-4 py-8 max-w-2xl">
  <%# ヘッダー %>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">銘菓を編集</h1>
    <p class="text-gray-600">銘菓の情報を更新してください</p>
  </div>

  <%# エラーメッセージ表示 %>
  <% if @sweet.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= @sweet.errors.count %>個のエラーがあります
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc list-inside">
            <% @sweet.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# フォーム %>
  <%= form_with model: @sweet, local: true, html: { class: "space-y-6", multipart: true } do |f| %>
    <%# 銘菓名 %>
    <div>
      <%= f.label :name, "銘菓名", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_field :name, 
          class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors",
          placeholder: "例: 白い恋人" %>
    </div>

    <%# 地域選択 %>
    <div>
      <%= f.label :region_id, "地域", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.collection_select :region_id, 
          Region.all, :id, :name,
          { prompt: "地域を選択してください" },
          class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors" %>
    </div>

    <%# 説明 %>
    <div>
      <%= f.label :description, "説明", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= f.text_area :description,
          rows: 6,
          class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors resize-none",
          placeholder: "銘菓の特徴や魅力を教えてください" %>
    </div>

    <%# 画像アップロード %>
    <div>
      <%= f.label :image, "画像", class: "block text-sm font-medium text-gray-700 mb-2" %>
      
      <%# 現在の画像プレビュー %>
      <% if @sweet.image.attached? %>
        <div class="mb-4">
          <p class="text-sm text-gray-600 mb-2">現在の画像:</p>
          <div class="relative inline-block">
            <%= image_tag @sweet.image.variant(resize_to_fill: [400, 300]), class: 'w-48 h-48 object-cover rounded-lg border border-gray-300' %>
          </div>
        </div>
      <% end %>

      <div class="flex items-center justify-center w-full">
        <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-gray-300 border-dashed rounded-lg cursor-pointer bg-gray-50 hover:bg-gray-100 transition-colors">
          <div class="flex flex-col items-center justify-center pt-5 pb-6">
            <svg class="w-10 h-10 mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
            </svg>
            <p class="mb-2 text-sm text-gray-500">
              <span class="font-semibold">クリックして画像を選択</span>
            </p>
            <p class="text-xs text-gray-500">PNG, JPG (最大10MB)</p>
          </div>
          <%= f.file_field :image, 
              class: "hidden",
              accept: "image/*" %>
        </label>
      </div>
    </div>

    <%# 送信ボタン %>
    <div class="flex gap-4 pt-4">
      <%= f.submit "更新する", 
          class: "flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-md transition-colors cursor-pointer" %>
      <%= link_to "キャンセル", 
          sweet_path(@sweet), 
          class: "flex-1 bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold py-3 px-6 rounded-md transition-colors text-center" %>
    </div>
  <% end %>
</div>