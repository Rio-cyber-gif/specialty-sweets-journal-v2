<!-- Header -->
<header class="border-b bg-white sticky top-0 z-10 shadow-sm">
  <div class="container mx-auto px-4 py-4">
    <div class="flex items-center justify-between">
      <!-- ロゴ -->
      <%= link_to root_path, class: "flex items-center gap-2.5 no-underline" do %>
        <span style="font-size: 30px; line-height: 1;">🍬</span>
        <div style="display: flex; flex-direction: column; line-height: 1.2;">
          <span style="font-family: Georgia, 'Times New Roman', serif; font-size: 1.05rem; font-weight: 700; letter-spacing: 0.03em; background: linear-gradient(90deg, #c9405a, #d97030, #b89010); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Specialty Sweets</span>
          <span style="font-family: Georgia, 'Times New Roman', serif; font-size: 0.6rem; font-weight: 400; letter-spacing: 0.22em; color: #a89080; text-transform: uppercase;">Journal</span>
        </div>
      <% end %>

      <!-- デスクトップナビゲーション -->
      <nav class="hidden md:flex items-center gap-4">
        <%= link_to guide_path, class: "inline-flex items-center text-sm font-medium rounded-md transition hover:bg-gray-100", style: "color: #8b7355; padding: 0.5rem 0.75rem;" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          使い方
        <% end %>
        <% if user_signed_in? %>
          <%= link_to mypage_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium rounded-md transition hover:bg-gray-100", style: "color: #8b7355;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            マイページ
          <% end %>

          <% if current_user.admin? %>
            <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 text-white font-medium rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]", style: "background-color: #8B4513;", onmouseover: "this.style.backgroundColor='#6B3410'", onmouseout: "this.style.backgroundColor='#8B4513'" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              管理画面
            <% end %>
          <% end %>

          <%= button_to destroy_user_session_path, method: :delete, form: { style: "display: inline;" }, class: "inline-flex items-center text-sm font-medium rounded-md transition hover:bg-gray-100", style: "color: #8b7355; background: none; border: none; cursor: pointer; font-family: inherit; padding: 0.5rem 0.75rem;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            ログアウト
          <% end %>

          <%= link_to new_specialty_path, class: "inline-flex items-center px-4 py-2 text-white font-medium rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]", style: "background-color: #8b7355;", onmouseover: "this.style.backgroundColor='#6d5a43'", onmouseout: "this.style.backgroundColor='#8b7355'" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            銘菓を投稿
          <% end %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, class: "inline-flex items-center text-sm font-medium rounded-md transition hover:bg-gray-100", style: "color: #8b7355; padding: 0.5rem 0.75rem;" %>

          <%= link_to new_user_registration_path, class: "inline-flex items-center px-4 py-2 text-white font-medium rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]", style: "background-color: #8b7355;", onmouseover: "this.style.backgroundColor='#6d5a43'", onmouseout: "this.style.backgroundColor='#8b7355'" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            新規登録
          <% end %>
        <% end %>
      </nav>

      <!-- ハンバーガーボタン（スマホのみ表示） -->
      <button id="hamburger-btn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 rounded-md transition hover:bg-gray-100" style="color: #8b7355;" aria-label="メニュー" aria-expanded="false">
        <span class="hamburger-line block w-5 h-0.5 mb-1 transition-all duration-300" style="background-color: #8b7355;"></span>
        <span class="hamburger-line block w-5 h-0.5 mb-1 transition-all duration-300" style="background-color: #8b7355;"></span>
        <span class="hamburger-line block w-5 h-0.5 transition-all duration-300" style="background-color: #8b7355;"></span>
      </button>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="md:hidden hidden border-t" style="border-color: #e8d5c4; background-color: #faf6f2;">
    <nav class="container mx-auto px-4 py-3 flex flex-col gap-1">
      <%= link_to guide_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition hover:bg-white", style: "color: #8b7355;" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        使い方
      <% end %>

      <% if user_signed_in? %>
        <%= link_to new_specialty_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition", style: "color: white; background-color: #8b7355;" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          銘菓を投稿
        <% end %>

        <%= link_to mypage_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition hover:bg-white", style: "color: #8b7355;" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          マイページ
        <% end %>

        <% if current_user.admin? %>
          <%= link_to admin_root_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition", style: "color: white; background-color: #8B4513;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            管理画面
          <% end %>
        <% end %>

        <div class="border-t pt-2 mt-1" style="border-color: #e8d5c4;">
          <%= button_to destroy_user_session_path, method: :delete, form: { class: "w-full" }, class: "w-full flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition hover:bg-white", style: "color: #8b7355; background: none; border: none; cursor: pointer; font-family: inherit;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            ログアウト
          <% end %>
        </div>
      <% else %>
        <div class="border-t pt-2 mt-1 flex flex-col gap-1" style="border-color: #e8d5c4;">
          <%= link_to "ログイン", new_user_session_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition hover:bg-white", style: "color: #8b7355;" %>
          <%= link_to new_user_registration_path, class: "flex items-center px-3 py-2.5 text-sm font-medium rounded-md transition", style: "color: white; background-color: #8b7355;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            新規登録
          <% end %>
        </div>
      <% end %>
    </nav>
  </div>
</header>

<script>
  (function() {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', function() {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));

      // ハンバーガー → ✕ アニメーション
      const lines = btn.querySelectorAll('.hamburger-line');
      if (!isOpen) {
        lines[0].style.transform = 'translateY(6px) rotate(45deg)';
        lines[1].style.opacity = '0';
        lines[2].style.transform = 'translateY(-6px) rotate(-45deg)';
      } else {
        lines[0].style.transform = '';
        lines[1].style.opacity = '';
        lines[2].style.transform = '';
      }
    });

    // メニュー内リンクをタップしたら閉じる
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        const lines = btn.querySelectorAll('.hamburger-line');
        lines[0].style.transform = '';
        lines[1].style.opacity = '';
        lines[2].style.transform = '';
      });
    });
  })();
</script>
