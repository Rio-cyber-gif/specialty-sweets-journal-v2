<div id="comment_form">
  <%= form_with model: [specialty, comment] do |f| %>
    <% if comment.errors.any? %>
      <div class="rounded-md p-3 mb-3" style="background-color: #fee; border: 1px solid #dc2626;">
        <ul class="list-disc list-inside text-sm" style="color: #dc2626;">
          <% comment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div class="space-y-3">
      <%= f.text_area :body,
          rows: 3,
          placeholder: "コメントを入力してください... (最大1000文字)",
          maxlength: 1000,
          class: "w-full px-3 py-2 text-sm rounded-md border focus:outline-none focus:ring-1",
          style: "border-color: #d4a574; color: #471e0a;" %>
      <%= f.submit "コメントを投稿",
          class: "px-4 py-2 text-sm font-medium text-white rounded-md cursor-pointer",
          style: "background-color: #8b5e3c;",
          data: { turbo_submits_with: "投稿中..." } %>
    </div>
  <% end %>
</div>
