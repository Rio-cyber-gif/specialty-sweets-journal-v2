<div class="min-h-screen py-12" style="background-color: #f5f5f0;">
  <div class="container mx-auto px-4 max-w-md">
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <!-- カードヘッダー -->
      <div class="px-6 py-4 bg-gray-50">
        <h1 class="text-2xl font-bold" style="color: #8b7355;">パスワードリセット</h1>
        <p class="text-sm mt-1" style="color: #8b7355;">
          登録したメールアドレスを入力してください
        </p>
      </div>

      <!-- カードコンテンツ -->
      <div class="px-6 pt-2 pb-6">
        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <!-- メールアドレス -->
          <div class="space-y-2">
            <%= f.label :email, "メールアドレス", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.email_field :email, 
                autofocus: true,
                autocomplete: "email",
                placeholder: "example@email.com",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- 送信ボタン -->
          <div class="pt-2">
            <%= f.submit "パスワードリセットメールを送信", 
                class: "w-full text-white font-medium py-2 px-4 rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]",
                style: "background-color: #8b7355;",
                onmouseover: "this.style.backgroundColor='#6d5a43'",
                onmouseout: "this.style.backgroundColor='#8b7355'" %>
          </div>
        <% end %>
      </div>

      <!-- カードフッター -->
      <div class="px-6 py-4 bg-gray-50">
        <div class="flex flex-col space-y-2 text-sm" style="color: #8b7355;">
          <%= link_to "ログインはこちら", new_session_path(resource_name), class: "hover:underline" %>
          <%= link_to "新規登録はこちら", new_registration_path(resource_name), class: "hover:underline" %>
        </div>
      </div>
    </div>
  </div>
</div>