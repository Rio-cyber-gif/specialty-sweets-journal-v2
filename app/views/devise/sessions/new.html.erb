<div class="min-h-screen py-12" style="background-color: #f5f5f0;">
  <div class="container mx-auto px-4 max-w-md">
    <div class="mb-4">
      <%= link_to root_path, class: "inline-flex items-center text-sm font-medium", style: "color: #8b7355;" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        ホームに戻る
      <% end %>
    </div>
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <!-- カードヘッダー -->
      <div class="px-6 py-4 bg-gray-50">
        <h1 class="text-2xl font-bold" style="color: #8b7355;">ログイン</h1>
        <p class="text-sm mt-1" style="color: #8b7355;">
          アカウントにログインして銘菓を投稿しましょう
        </p>
      </div>

      <!-- カードコンテンツ -->
      <div class="px-6 pt-2 pb-6">
        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
          <!-- メールアドレス -->
          <div class="space-y-2">
            <%= f.label :email, "メールアドレス", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.email_field :email, 
                autofocus: true,
                autocomplete: "email",
                placeholder: "example@email.com",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- パスワード -->
          <div class="space-y-2">
            <%= f.label :password, "パスワード", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.password_field :password,
                autocomplete: "current-password",
                placeholder: "パスワードを入力",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- ログインボタン -->
          <div class="pt-2">
            <%= f.submit "ログイン", 
                class: "w-full text-white font-medium py-2 px-4 rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]",
                style: "background-color: #8b7355;",
                onmouseover: "this.style.backgroundColor='#6d5a43'",
                onmouseout: "this.style.backgroundColor='#8b7355'" %>
          </div>
        <% end %>
      </div>

      <!-- カードフッター -->
      <div class="px-6 py-4 bg-gray-50">
        <div class="flex flex-col space-y-2 text-sm" style="color: #8b7355;">
          <% if devise_mapping.registerable? && controller_name != 'registrations' %>
            <%= link_to "新規登録", new_registration_path(resource_name), class: "hover:underline" %>
          <% end %>
          <%# パスワードリセット機能を一時的に無効化 %>
          <%# if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
            <%#= link_to "パスワードリセット", new_password_path(resource_name), class: "hover:underline" %>
          <%# end %>
        </div>
      </div>
    </div>
  </div>
</div>