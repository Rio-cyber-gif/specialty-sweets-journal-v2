<div class="min-h-screen py-12" style="background-color: #f5f5f0;">
  <div class="container mx-auto px-4 max-w-md">
    <div class="mb-4">
      <%= link_to root_path, class: "inline-flex items-center text-sm font-medium", style: "color: #8b7355;" do %>
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        ホームに戻る
      <% end %>
    </div>
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <!-- カードヘッダー -->
      <div class="px-6 py-4 bg-gray-50">
        <h1 class="text-2xl font-bold" style="color: #8b7355;">新規登録</h1>
        <p class="text-sm mt-1" style="color: #8b7355;">
          アカウントを作成して銘菓を投稿しましょう
        </p>
      </div>

      <!-- カードコンテンツ -->
      <div class="px-6 pt-2 pb-6">
        <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
              html: { class: "space-y-4", novalidate: true, enctype: "multipart/form-data" }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <!-- アイコン画像（任意） -->
          <div class="space-y-2">
            <%= f.label :avatar, "アイコン画像（任意）", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <div class="flex flex-col items-center gap-3">
              <div id="avatar_preview_wrapper" style="display: none;">
                <img id="avatar_preview" src="" alt="プレビュー"
                     class="rounded-full object-cover border-2"
                     style="width: 72px; height: 72px; border-color: #d4a574;">
              </div>
              <%= f.file_field :avatar, accept: "image/*", id: "avatar_input",
                  class: "w-full text-xs",
                  style: "color: #8b7355;" %>
            </div>
            <script>
              document.getElementById('avatar_input').addEventListener('change', function(e) {
                var file = e.target.files[0];
                var wrapper = document.getElementById('avatar_preview_wrapper');
                var preview = document.getElementById('avatar_preview');
                if (file && file.type.startsWith('image/')) {
                  preview.src = URL.createObjectURL(file);
                  wrapper.style.display = 'block';
                } else {
                  wrapper.style.display = 'none';
                  preview.src = '';
                }
              });
            </script>
          </div>

          <!-- お名前 -->
          <div class="space-y-2">
            <%= f.label :name, "お名前", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.text_field :name, 
                autofocus: true,
                placeholder: "山田太郎",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- メールアドレス -->
          <div class="space-y-2">
            <%= f.label :email, "メールアドレス", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.email_field :email, 
                autocomplete: "email",
                placeholder: "example@email.com",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- パスワード -->
          <div class="space-y-2">
            <%= f.label :password, "パスワード", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <% if @minimum_password_length %>
              <p class="text-xs" style="color: #8b7355;">(<%= @minimum_password_length %> 文字以上)</p>
            <% end %>
            <%= f.password_field :password,
                autocomplete: "new-password",
                placeholder: "6文字以上",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- パスワード確認 -->
          <div class="space-y-2">
            <%= f.label :password_confirmation, "パスワード(確認)", class: "block text-sm font-medium", style: "color: #8b7355;" %>
            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "パスワードを再入力",
                required: true,
                class: "w-full px-3 py-2 border-2 rounded-md shadow-sm focus:outline-none focus:ring-2",
                style: "border-color: #8b7355;" %>
          </div>

          <!-- 登録ボタン -->
          <div class="pt-2">
            <%= f.submit "登録", 
                class: "w-full text-white font-medium py-2 px-4 rounded-md transition duration-200 ease-in-out transform hover:scale-[1.02]",
                style: "background-color: #8b7355;",
                onmouseover: "this.style.backgroundColor='#6d5a43'",
                onmouseout: "this.style.backgroundColor='#8b7355'" %>
          </div>
        <% end %>
      </div>

      <!-- カードフッター -->
      <div class="px-6 py-4 bg-gray-50">
        <div class="flex flex-col space-y-2 text-sm" style="color: #8b7355;">
          <%= link_to "ログインはこちら", new_session_path(resource_name), class: "hover:underline" %>
        </div>
      </div>
    </div>
  </div>
</div>