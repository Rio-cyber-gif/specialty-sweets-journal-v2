<div class="container mx-auto px-4 py-8 max-w-4xl">
  <%# 戻るボタン %>
  <div class="mb-6">
    <%= link_to root_path, class: "inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
      一覧に戻る
    <% end %>
  </div>

  <%# カード %>
  <div class="bg-white rounded-lg shadow-md">
    <div class="p-6">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">銘菓を投稿</h1>

      <%= form_with model: @sweet, url: sweets_path, local: true, class: "space-y-6" do |f| %>
        <%# エラーメッセージ表示 %>
        <% if @sweet.errors.any? %>
          <div class="bg-red-50 border border-red-300 text-red-800 px-4 py-3 rounded-lg">
            <h2 class="font-bold mb-2 text-lg">
              <%= @sweet.errors.count %>件のエラーが発生しました
            </h2>
            <ul class="list-disc list-inside space-y-1">
              <% @sweet.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%# 銘菓名 %>
        <div>
          <%= f.label :name, '銘菓名', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_field :name, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: '例: 白い恋人' %>
        </div>

        <%# 説明 %>
        <div>
          <%= f.label :description, '説明', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.text_area :description, rows: 5, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', placeholder: '銘菓の説明を入力してください' %>
        </div>

        <%# 地域 %>
        <div>
          <%= f.label :region_id, '地域', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.collection_select :region_id, @regions, :id, :name, { prompt: '地域を選択してください' }, { class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent' } %>
        </div>

        <%# 画像 %>
        <div>
          <%= f.label :image, '画像', class: 'block text-sm font-medium text-gray-700 mb-2' %>
          <%= f.file_field :image, class: 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent', accept: 'image/*' %>
          <p class="mt-2 text-sm text-gray-500">JPG、PNG、GIF形式の画像をアップロードできます</p>
        </div>

        <%# 送信ボタン %>
        <div class="flex gap-4">
          <%= f.submit '投稿する', class: 'px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors cursor-pointer' %>
          <%= link_to 'キャンセル', root_path, class: 'px-6 py-2 bg-gray-200 text-gray-700 font-medium rounded-lg hover:bg-gray-300 transition-colors' %>
        </div>
      <% end %>
    </div>
  </div>
</div>